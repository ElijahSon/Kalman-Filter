# =========================================================
# MATLAB / Simulink Professional .gitignore
# Optimized for GitHub engineering repositories
# =========================================================

# =========================================================
# MATLAB autosave / backup files
# =========================================================

*.asv
*.autosave
*.m~


# =========================================================
# Simulink generated cache / build folders
# =========================================================

slprj/
sccprj/
simulink_cache/
cache/
codegen/
generated/


# =========================================================
# Simulink cache files
# =========================================================

*.slxc


# =========================================================
# MATLAB compiled binaries
# =========================================================

*.mex*
*.p
*.mlappinstall


# =========================================================
# MATLAB crash dumps / logs
# =========================================================

matlab_crash_dump.*
hs_err_pid*
*.log


# =========================================================
# Simulink / Embedded Coder generated files
# =========================================================

*.rtw
*.tmf
*.mk
*.obj
*.o
*.dll
*.exe
*.exp
*.lib


# =========================================================
# Coverage / testing artifacts
# =========================================================

coverage/
slcoverage/
test_results/


# =========================================================
# Temporary simulation outputs
# =========================================================

*.tmp
*.temp


# =========================================================
# Optional large generated datasets
# Uncomment if simulation outputs are huge
# =========================================================

# *.mat
# *.csv
# *.dat


# =========================================================
# Operating system files
# =========================================================

# macOS
.DS_Store

# Windows
Thumbs.db
desktop.ini


# =========================================================
# Editors / IDEs
# =========================================================

# VS Code
.vscode/

# JetBrains
.idea/

# MATLAB Project local settings
resources/project/Root.type.Files/


# =========================================================
# Python cache (if co-simulation/scripts are used)
# =========================================================

__pycache__/
*.pyc


# =========================================================
# Archives
# =========================================================

*.zip
*.rar
*.7z
*.tar.gz


# =========================================================
# Build / distribution folders
# =========================================================

build/
dist/
out/


# =========================================================
# KEEP THESE FILE TYPES TRACKED
# (DO NOT IGNORE)
# =========================================================
#
# *.m
# *.mlx
# *.slx
# *.mdl
# *.prj
# *.pdf
#
# =========================================================